{
  "name": "invoice-il",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "pnpm --filter @invoice/db run build && pnpm --filter @invoice/shared run build && turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @invoice/db db:generate",
    "db:migrate": "pnpm --filter @invoice/db db:migrate",
    "db:push": "pnpm --filter @invoice/db db:push"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
